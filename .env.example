# ─────────────────────────────────────────────────────────────────────────────
# Vercel 배포용 환경변수 (Vercel Project → Settings → Environment Variables)
# 모든 변수에 코드상 fallback이 있어 미설정이어도 빌드는 통과하지만,
# 프로덕션 동작을 위해 아래 값을 설정하세요.
# ─────────────────────────────────────────────────────────────────────────────

# ── 공개 URL (sitemap / robots / canonical) ──
# src/app/sitemap.ts, robots.ts 에서 사용. 미설정 시 https://deepingsource.io
NEXT_PUBLIC_BASE_URL=https://deepingsource.io

# ── 공개 배포 origin ──
# 배포 도메인과 일치시킬 것. (Keystatic GitHub 모드의 OAuth 콜백 등에 참조)
NEXT_PUBLIC_SITE_URL=https://deepingsource.io

# ── 폼 제출 알림 (Slack Incoming Webhook) ──
# /api/contact, /api/newsletter 제출이 이 webhook 으로 전송됨. (server-only, 비공개)
# enterprise 리드(?type=enterprise)는 '🏢 [ENTERPRISE]' 프리픽스로 구분됨.
SLACK_WEBHOOK_URL=

# ── 리드 저장 (Google Sheets append · 선택) ──
# /api/contact 제출을 Google Sheet 한 행으로 append(server-only, src/lib/lead-store.ts).
# 아래 3개가 모두 설정돼야 켜지고, 미설정이면 무해한 no-op(Slack 경로는 그대로 동작).
# 준비: ① Google Cloud 서비스계정 생성 + Sheets API 활성화 ② 대상 시트에 서비스계정
# 이메일을 '편집자'로 공유 ③ 시트 첫 행에 헤더(시간·소스·이름·연락처·매장수·소속·
# 브랜드·제품·플랜·문의유형·메시지). 열 순서 = lead-store.ts 의 row 배열.
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# 개인키의 줄바꿈은 리터럴 "\n" 으로 넣어도 됨(코드에서 복원). 따옴표로 감쌀 것.
GOOGLE_PRIVATE_KEY=
# (선택) append 대상 범위. 미설정 시 "Leads!A:K".
GOOGLE_SHEETS_RANGE=

# ── Keystatic GitHub App (현행: GitHub 모드) ──
# 현재 CMS는 GitHub 모드(DeepingSource/ds-hp-temp). 미설정 시 /keystatic 어드민만
# 503이고 사이트 빌드·배포는 정상(route.ts 가드). Production + Preview 모두에 설정.
# NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG는 빌드타임 인라인 → 설정 후 재배포 필수.
# 생성/설정 절차: docs/PHASE_C_github-mode-setup.md
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# ── 색인 허용 (운영 도메인에서만 true) ──
# 미설정/false면 noindex + robots Disallow:/ (임시 도메인·프리뷰 보호).
# 운영 배포(deepingsource.io)에만 =true 로 설정. src/app/layout.tsx·robots.ts 에서 사용.
NEXT_PUBLIC_ALLOW_INDEXING=

# ── 편집 가이드(/help) 프로덕션 노출 (기본: 프로덕션 제외) ──
# /help 는 비공개 레포명·CMS/배포 절차를 노출하는 내부 편집자 가이드다.
# 기본 동작: VERCEL_ENV==='production' 이면 notFound()(로컬·프리뷰에선 노출).
# 프로덕션에서도 강제로 노출해야 할 때만 =true. src/app/help/page.tsx 에서 사용.
ENABLE_EDITOR_GUIDE=

# ── GA4 애널리틱스 (선택) ──
# GA4 속성 → 데이터 스트림에서 발급받은 측정 ID (형식: G-XXXXXXXXXX).
# 설정 시 layout.tsx가 <GoogleAnalytics />를 로드. ⚠ preview/staging 배포에는
# 설정하지 말 것(프로덕션 데이터 오염 방지). CSP는 next.config.ts에서 이미 허용됨.
NEXT_PUBLIC_GA_ID=

# ── Umami 애널리틱스 (선택) ──
# Umami Cloud 권장. 스크립트 URL 예: https://cloud.umami.is/script.js
# 자가호스팅 시 해당 도메인을 next.config.ts CSP(script-src·connect-src)에 추가.
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# ── 제한 문서(gated docs) 접근 (선택 · DOCS_WIKI_PLAN Phase 4) ──
# 문서 frontmatter 에 access:gated 를 지정하면 /resources/docs/<슬러그> 는 공유
# 액세스 코드가 있어야 열람 가능(코드→서명 쿠키, proxy 게이트). 아래 둘 다 설정해야
# 활성화됨. 미설정 시 fail-closed(gated 문서는 아무도 열람 불가). gated 문서가 하나도
# 없으면 이 기능은 완전 무동작(사이트 영향 없음).
#   DOCS_ACCESS_SECRET — HMAC 서명 비밀키(길고 무작위인 문자열, server-only).
#                        예: openssl rand -hex 32
#   DOCS_ACCESS_CODES  — 쉼표 구분 `라벨:코드` 쌍. 라벨(콜론 앞)만 로그에 남으니 코드는
#                        안전. 라벨 없이 코드만 써도 되지만(그땐 'access' 로 로깅) 고객사별
#                        감사 로그를 남기려면 `라벨:코드` 형식 권장.
#                        ⚠️ 코드는 반드시 길고 무작위로(예: openssl rand -base64 18).
#                        rate limit 은 인스턴스별 best-effort(XFF 스푸핑 가능)이므로
#                        브루트포스 저항은 사실상 코드 엔트로피에 의존한다.
#                        예: acme:9fK2xQ7mLpZ, globex:vT4nR8sW1yB
DOCS_ACCESS_SECRET=
DOCS_ACCESS_CODES=

# ── 미니사이트 강제 표시 (개발/디버그용, 기본 false) ──
# FORCE_MINISITE=false

# ─────────────────────────────────────────────────────────────────────────────
# 주의: GH_PAGES / NEXT_PUBLIC_BASE_PATH 는 GitHub Pages 정적 export 전용.
#       Vercel 에서는 절대 설정하지 말 것 (설정 시 서버 모드가 깨짐).
# ─────────────────────────────────────────────────────────────────────────────
